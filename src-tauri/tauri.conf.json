{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firelink",
  "version": "0.7.3",
  "identifier": "com.nimbold.firelink",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ../scripts/verify-binaries.js && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Firelink",
        "width": 1280,
        "height": 760,
        "minWidth": 1180,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 17,
          "y": 28
        },
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar", "mica"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:* http://localhost:* http://127.0.0.1:* ws://127.0.0.1:*"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/aria2c",
      "binaries/ffmpeg",
      "binaries/deno"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/**/*"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["firelink"]
      }
    }
  }
}
